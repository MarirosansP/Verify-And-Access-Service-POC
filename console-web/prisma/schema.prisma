generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  name                 String?
  passwordHash         String
  isAdmin              Boolean              @default(false)
  isFrozen             Boolean              @default(false)
  createdAt            DateTime             @default(now())
  apiKeys              ApiKey[]
  usageEvents          UsageEvent[]
  workerKeys           WorkerKey[]
  workerUsageEvents    WorkerUsageEvent[]
  verificationRecords  VerificationRecord[]
  passwordResetTokens  PasswordResetToken[]
}

model ApiKey {
  id          String       @id @default(cuid())
  userId      String
  name        String
  prefix      String       @unique
  keyHash     String
  status      String       @default("active") // active|paused|revoked
  createdAt   DateTime     @default(now())
  lastUsedAt  DateTime?
  user        User         @relation(fields: [userId], references: [id])
  usageEvents UsageEvent[]
}

model UsageEvent {
  id             String   @id @default(cuid())
  userId         String
  apiKeyId       String
  ts             DateTime @default(now())
  endpoint       String
  statusCode     Int
  durationMs     Int
  merchantOrigin String?
  user           User     @relation(fields: [userId], references: [id])
  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id])
}

model WorkerKey {
  id                String             @id @default(cuid())
  userId            String
  keyHash           String             @unique
  siteName          String
  siteUrl           String
  callbackPath      String             @default("/")
  status            String             @default("active") // active|paused|revoked
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id])
  workerUsageEvents WorkerUsageEvent[]
}

/// Stores the result of each completed verification (verified or failed).
/// Visible only to the account owner — admin cannot access these records.
model VerificationRecord {
  id               String    @id @default(cuid())
  userId           String
  workerKeyId      String?
  sessionId        String    @unique
  challenge        String
  siteName         String
  siteUrl          String
  status           String    // "verified" | "failed"
  auditRecordId    String?
  presentationJson String?
  failureReason    String?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id])
}

/// One-time password reset token. Expires after 1 hour, single-use.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique  // SHA256 of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

/// Tracks each call to /api/worker/initiate (one per verification session started).
/// Used for per-key usage stats and hourly quota enforcement.
model WorkerUsageEvent {
  id          String    @id @default(cuid())
  userId      String
  workerKeyId String
  ts          DateTime  @default(now())
  sessionId   String?
  user        User      @relation(fields: [userId], references: [id])
  workerKey   WorkerKey @relation(fields: [workerKeyId], references: [id])
}
